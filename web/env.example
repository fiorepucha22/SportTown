# Copiar a web/.env para desarrollo local con Vite.
#
# Producción (build en el VPS): dejar VITE_API_URL vacío.
# El frontend llama a rutas relativas /api y Nginx las enruta a Laravel.
#
# Desarrollo con proxy Vite (recomendado): vacío + php artisan serve en backend
# VITE_API_URL=
#
# Desarrollo sin proxy (fetch directo al backend):
# VITE_API_URL=http://127.0.0.1:8000
#
# Proxy de Vite hacia el backend en dev (opcional, por defecto 127.0.0.1:8000):
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

VITE_API_URL=
